# ai session router — configuration example
# Copy to: ${XDG_CONFIG_HOME:-~/.config}/ai-session-router/router.env
# All values are optional; unset ones fall back to the defaults shown.

# Workspaces (files + logs live here)
AI_PERSONAL_WS="$HOME/dev/personal"
AI_COMPANY_WS="$HOME/dev/work"

# Account config-root prefixes; the router appends <account> (personal|company)
# e.g. CLAUDE_CONFIG_DIR=${AI_CLAUDE_ROOT_PREFIX}personal
AI_CLAUDE_ROOT_PREFIX="$HOME/.claude-"
AI_CODEX_ROOT_PREFIX="$HOME/.codex-"

# Browser identity (company GUI)
AI_CHROME_COMPANY_PROFILE="Work"
AI_COMPANY_CHATGPT_URL="https://chatgpt.com/"
AI_COMPANY_CLAUDE_URL="https://claude.ai/"

# Native desktop GUI apps (macOS). `ai gui` launches these isolated per account via
# `open -n -a <bundle> --args --user-data-dir=<prefix><account>`. App data dirs are
# SEPARATE from the CLI roots above. Native isolation is Electron-only (Claude.app);
# native AppKit apps like ChatGPT ignore --user-data-dir, so they are not listed here.
AI_CLAUDE_APP="/Applications/Claude.app"
AI_CLAUDE_APP_DATA_PREFIX="$HOME/.claude-app-"
AI_GUI_APPS="claude"   # space-separated list of Electron apps to launch isolated

# Shared support dir
AI_SHARED="$HOME/.ai-shared"
