# ai session router — configuration example
# Copy to: ${XDG_CONFIG_HOME:-~/.config}/ai-session-router/router.env
# All values are optional; unset ones fall back to the defaults shown.

# Workspaces (files + logs live here)
AI_PERSONAL_WS="$HOME/dev/personal"
AI_COMPANY_WS="$HOME/dev/work"

# Account config-root prefixes; the router appends <account> (personal|company)
# e.g. CLAUDE_CONFIG_DIR=${AI_CLAUDE_ROOT_PREFIX}personal
AI_CLAUDE_ROOT_PREFIX="$HOME/.claude-"
AI_CODEX_ROOT_PREFIX="$HOME/.codex-"

# Browser isolation (generic `ai gui` browser path)
# One identity = one isolated browser instance. The DEFAULT mechanism launches the
# browser with --user-data-dir=<prefix><id>, which auto-creates an isolated instance
# (its own storage, no pre-existing profile required) — the same mechanism the native
# desktop app uses. Signing into the browser account inside that data-dir triggers
# Chromium sync, so bookmarks/extensions/passwords fill in over time.

# Default browser for isolated GUI launches (macOS app name / linux binary).
# Empty → auto-detect first available Chromium browser; else the OS default browser.
AI_BROWSER="Microsoft Edge"

# Prefix for per-identity isolated user-data dirs; the router appends <id>.
# e.g. AI_BROWSER_DATA_PREFIX="$HOME/.ai-browser-" → ~/.ai-browser-company
AI_BROWSER_DATA_PREFIX="$HOME/.ai-browser-"

# Optional per-identity overrides (all optional; unset → fall back to the defaults above):
AI_GUI_BROWSER_personal=""              # override AI_BROWSER for this identity
AI_GUI_BROWSER_company=""
AI_GUI_URLS_personal=""                 # space-separated URLs to open on launch
AI_GUI_URLS_company="https://chatgpt.com/ https://claude.ai/"
AI_GUI_PROFILE_personal=""              # set → opt into --profile-directory (existing profile) instead of isolated data-dir
AI_GUI_PROFILE_company=""

# Upgrade note (pre-generic configs): these legacy vars are still honored as
# fallbacks when the new vars above are unset. Leave them COMMENTED here — setting
# AI_CHROME_COMPANY_PROFILE forces the company identity onto Google Chrome + that
# profile instead of the isolated-data-dir default. Uncomment only to reproduce
# the old behavior.
#AI_CHROME_COMPANY_PROFILE="Work"
#AI_COMPANY_CHATGPT_URL="https://chatgpt.com/"
#AI_COMPANY_CLAUDE_URL="https://claude.ai/"

# Native desktop GUI apps (macOS). `ai gui` launches these isolated per account via
# `open -n -a <bundle> --args --user-data-dir=<prefix><account>`. App data dirs are
# SEPARATE from the CLI roots above. Native isolation is Electron-only (Claude.app);
# native AppKit apps like ChatGPT ignore --user-data-dir, so they are not listed here.
AI_CLAUDE_APP="/Applications/Claude.app"
AI_CLAUDE_APP_DATA_PREFIX="$HOME/.claude-app-"
AI_GUI_APPS="claude"   # space-separated list of Electron apps to launch isolated

# Shared support dir
AI_SHARED="$HOME/.ai-shared"
