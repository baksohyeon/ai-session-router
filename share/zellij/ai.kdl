// ai-session-router default Zellij layout (layout-as-code).
// `ai zellij <workspace>` starts a session named ai-<workspace> with this layout,
// launched from the workspace root so every pane inherits that cwd.
//
// Panes are plain shells on purpose (no auto-launched agents): run `ai claude <ws>`
// or `ai codex <ws>` in a pane when you want one. The tab-bar and status-bar keep
// Zellij's keybindings visible, so there is no prefix-key muscle memory to build.
//
// Customize per machine by copying this file and pointing AI_ZELLIJ_LAYOUT at it
// (see examples/router.env.example).
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="work" focus=true {
        pane split_direction="vertical" {
            pane name="main"
            pane size="38%" split_direction="horizontal" {
                pane name="aux"
                pane name="logs"
            }
        }
    }
}
